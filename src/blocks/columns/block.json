{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"textdomain": "comet",
	"name": "comet/columns",
	"title": "Columns",
	"icon": "columns",
	"description": "Add a section with multiple blocks, displayed side-by-side when there is enough space",
	"category": "design",
	"acf": {
		"mode": "edit",
		"renderTemplate": "render.php",
		"blockVersion": 3,
		"hideFieldsInSidebar": true
	},
	"allowedBlocks": [
		"comet/copy",
		"comet/group"
	],
	"keywords": [
		"content",
		"columns",
		"layout"
	],
	"providesContext": {
		"isNested": "isParent",
		"parent": "name"
	},
	"attributes": {
		"size": {
			"type": "string",
			"default": "contained"
		},
		"backgroundColor": {
			"type": "string",
			"default": "none"
		},
		"sectionBackground": {
			"type": "string",
			"default": "none"
		},
		"isParent": {
			"type": "boolean",
			"default": true
		},
		"qty": {
			"type": "number",
			"default": 2
		},
		"columnLayout": {
			"type": "string",
			"default": "even"
		},
		"hAlign": {
			"type": "string",
			"default": "center"
		},
		"vAlign": {
			"type": "string",
			"default": "start"
		}
	},
	"supports": {
		"mode": false,
		"jsx": true,
		"innerBlocks": true,
		"anchor": true,
		"align": false
	}
}

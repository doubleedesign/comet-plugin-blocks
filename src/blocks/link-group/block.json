{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "comet/link-group",
	"textdomain": "comet",
	"title": "Link group",
	"icon": "admin-links",
	"description": "List a collection of external or featured links",
	"category": "design",
	"acf": {
		"mode": "edit",
		"renderTemplate": "render.php",
		"blockVersion": 3,
		"hideFieldsInSidebar": true
	},
	"keywords": [
		"link",
		"links"
	],
	"usesContext": [
		"isNested"
	],
	"attributes": {
		"size": {
			"type": "string",
			"default": "contained"
		},
		"colorTheme": {
			"type": "string",
			"default": "primary"
		},
		"layout": {
			"type": "string",
			"default": "list"
		},
		"maxPerRow": {
			"type": "number",
			"default": 3
		},
		"hAlign": {
			"type": "string",
			"default": "start"
		}
	},
	"supports": {
		"mode": true,
		"jsx": true,
		"innerBlocks": false,
		"colorTheme": true,
		"anchor": true,
		"align": false
	}
}
